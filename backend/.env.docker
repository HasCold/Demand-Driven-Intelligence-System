PORT=8000
X_BEAT_CONDUCTOR_PORT=6000
X_BEAT_PRICE_SETTLER_PORT=6001
# Keep Docker behavior close to local development defaults.
NODE_ENV=development

# Docker-specific overrides only.
TRUST_PROXY=false

CRAWLER_ENABLED=true
CRAWLER_RUN_ONCE=false
# In Docker, use service DNS names (not localhost) for crawler targets.
CRAWLER_SOURCES_JSON=[{"site":"sim5173","baseUrl":"http://bachat-bazaar-frontend","searchUrl":"http://bachat-bazaar-frontend/search?q=","apiBaseUrl":"http://xbeat-backend:8000/api/v1/bachat-bazaar"},{"site":"sim3000","baseUrl":"http://shophub-frontend:3000","searchUrl":"http://shophub-frontend:3000/products?search=","apiBaseUrl":"http://xbeat-backend:8000/api/v1/shophub"}]

PRICE_SETTLER_ENABLED=true
